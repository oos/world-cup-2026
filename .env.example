# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=dev-secret-change-in-production
DATABASE_URL=postgresql://wc26:wc26@db:5432/wc26

# Postgres (production Docker Compose)
POSTGRES_USER=wc26
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=wc26

# Database backups (Hetzner Object Storage — S3-compatible)
# Create a bucket in Hetzner Console → Object Storage, then add access keys.
S3_BUCKET=football
# e.g. https://fsn1.your-objectstorage.com (use your bucket region)
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: prefix inside the bucket, local retention (days), remote retention (days)
S3_PREFIX=database/
RETENTION_DAYS=7
S3_RETENTION_DAYS=30

# Ingestion
SYNC_SCRAPERS=true
APP_DOMAIN=http://localhost:5173
# API-Football (api-sports) — https://www.api-football.com/documentation-v3
# Free plan: seasons 2022–2024 only. World Cup 2026 needs Pro ($19/mo) or higher.
API_FOOTBALL_KEY=
API_FOOTBALL_SEASON=2026
# Proof mode: daily WC 2022 showcase sync on free tier (set false after Pro upgrade)
API_FOOTBALL_PROOF_MODE=true
API_FOOTBALL_PROOF_SEASON=2022
API_FOOTBALL_PROOF_MATCH_KEY=2022-12-18-argentina-vs-france
API_FOOTBALL_DAILY_BUDGET=95

# Auth (Resend — optional in dev; magic links logged to stdout when unset)
RESEND_API_KEY=
AUTH_FROM_EMAIL=noreply@YOUR_DOMAIN
AUTH_TOKEN_TTL_MINUTES=15
SESSION_COOKIE_MAX_AGE=2592000
ESPN_COMMENTARY_DELAY=6

# Frontend (Vite)
VITE_API_URL=http://localhost:5001
VITE_ENABLE_ADS=false
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX
# Google Analytics 4 — create at https://analytics.google.com, set stream URL to your domain
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@example.com
