# Flask
FLASK_ENV=development
FLASK_SECRET_KEY=dev-secret-change-in-production
DATABASE_URL=postgresql://wc26:wc26@db:5432/wc26

# Postgres (production Docker Compose)
POSTGRES_USER=wc26
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=wc26

# Ingestion
SYNC_SCRAPERS=true
APP_DOMAIN=http://localhost:5173

# Auth (Resend — optional in dev; magic links logged to stdout when unset)
RESEND_API_KEY=
AUTH_FROM_EMAIL=noreply@YOUR_DOMAIN
AUTH_TOKEN_TTL_MINUTES=15
SESSION_COOKIE_MAX_AGE=2592000
ESPN_COMMENTARY_DELAY=6

# Frontend (Vite)
VITE_API_URL=http://localhost:5001
VITE_ENABLE_ADS=false
VITE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Push notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:admin@example.com
