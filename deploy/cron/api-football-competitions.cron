# Daily API-Football competition backfill (~90 requests, free-tier historical seasons).
# Install with: deploy/scripts/install-cron.sh
#
30 6 * * * cd /opt/world-cup-2026 && docker compose -f docker-compose.prod.yml exec -T api flask --app wsgi sync-api-football-competitions >> /var/log/wc26-api-football-competitions.log 2>&1
